---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FounderSection from '../components/FounderSection.astro';
import SplitSection from '../components/SplitSection.astro';
import CtaBand from '../components/CtaBand.astro';
import { IMAGES } from '../data/images';
import { breadcrumbSchema, founderSchema } from '../utils/seo';
---

<Layout
  title="About"
  description="Learn about Brandtrove and founder Virender—strategic brand partnership firm connecting brands with athletes, celebrities, and creators across India and global markets."
  path="/about"
  ogImage={IMAGES.founder}
  jsonLd={[breadcrumbSchema([{ name: 'Home', path: '/' }, { name: 'About', path: '/about' }]), founderSchema()]}
>
  <PageHero
    eyebrow="About Brandtrove"
    title="Strategic Impact Through Cultural Relevance"
    lead="Brandtrove facilitates high-level strategic partnerships between premium brands and cultural icons—with an India-first approach and global execution capability."
    image={IMAGES.hero}
  />
  <div class="container" style="margin-top:-1rem;margin-bottom:1rem">
    <Breadcrumbs items={[{ name: 'Home', path: '/' }, { name: 'About', path: '/about' }]} />
  </div>

  <SplitSection
    image={IMAGES.strategy}
    alt="Brand partnership strategy session"
    eyebrow="Who We Are"
    title="Not a Directory of Names—An Execution Partner"
    description="From discovery and talent fit to deal structuring, campaign rollout, and performance review, we manage the full collaboration lifecycle across sports, entertainment, and influencer ecosystems."
    href="/services"
    linkLabel="View services"
  />

  <FounderSection />

  <section class="section section-tight">
    <div class="container">
      <div class="section-head centered">
        <span class="eyebrow">Our Mission</span>
        <h2>From Visibility to Cultural Relevance</h2>
        <p class="lead">
          We help brands build credibility, audience connection, and long-term equity through professionally
          managed partnerships—not one-time visibility plays.
        </p>
      </div>
      <div class="grid-3">
        <article class="card"><h3>Strategy-Led</h3><p>Partnerships engineered around business objectives—not just fame.</p></article>
        <article class="card"><h3>Network-Driven</h3><p>Access to athletes, celebrities, and creators through established channels.</p></article>
        <article class="card"><h3>Execution-Focused</h3><p>Professional coordination across digital, media, and on-ground activations.</p></article>
      </div>
    </div>
  </section>

  <CtaBand title="Ready to build your next brand collaboration?" />
</Layout>
