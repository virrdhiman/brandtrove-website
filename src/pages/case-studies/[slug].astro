---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaBand from '../../components/CtaBand.astro';
import { CASE_STUDIES, getCaseStudy } from '../../data/case-studies';
import { getCaseStudyContent } from '../../data/case-study-content';
import { SITE } from '../../data/site';
import { breadcrumbSchema } from '../../utils/seo';
import { renderContentBlocks } from '../../utils/content';

export function getStaticPaths() {
  return CASE_STUDIES.map((study) => ({ params: { slug: study.slug } }));
}

const { slug } = Astro.params;
const study = getCaseStudy(slug!);
if (!study) return Astro.redirect('/case-studies');

const content = getCaseStudyContent(study.slug, study.description);
const blocks = renderContentBlocks(content);
const pagePath = `/case-studies/${study.slug}`;
const ogImage = study.image ?? SITE.ogImage;
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Case Studies', path: '/case-studies' },
  { name: study.title, path: pagePath },
];
---

<Layout
  title={study.title}
  description={study.description}
  path={pagePath}
  type="article"
  ogImage={ogImage}
  jsonLd={[
    breadcrumbSchema(breadcrumbs),
    {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: study.title,
      description: study.description,
      image: `${SITE.url}${ogImage}`,
      datePublished: study.date,
      author: { '@type': 'Organization', name: SITE.name, url: SITE.url },
      publisher: {
        '@type': 'Organization',
        name: SITE.name,
        logo: { '@type': 'ImageObject', url: `${SITE.url}${SITE.logo}` },
      },
      mainEntityOfPage: { '@type': 'WebPage', '@id': `${SITE.url}${pagePath}` },
      articleSection: study.category,
    },
  ]}
>
  <article class="section">
    <div class="container prose">
      <Breadcrumbs items={breadcrumbs} />
      <span class="eyebrow">{study.category} · {study.clientType}</span>
      <h1>{study.title}</h1>
      <div class="metrics-row">
        {study.metrics.map((m) => (
          <div class="metric-pill">
            <strong>{m.value}</strong>
            <span>{m.label}</span>
          </div>
        ))}
      </div>
      {
        study.image && (
          <figure class="article-hero">
            <img src={study.image} alt="" width="1200" height="630" loading="eager" decoding="async" />
          </figure>
        )
      }
      {
        blocks.map((block) => {
          if (block.type === 'h2') return <h2>{block.text}</h2>;
          if (block.type === 'h3') return <h3>{block.text}</h3>;
          return <p>{block.text}</p>;
        })
      }
    </div>
  </article>
  <CtaBand title="Start a strategic partnership inquiry" />
</Layout>

<style>
  .article-hero {
    margin: 1.5rem 0 2rem;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .article-hero img {
    width: 100%;
    height: auto;
    display: block;
    max-height: 420px;
    object-fit: cover;
  }

  .metrics-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin: 1rem 0 1.25rem;
  }

  .metric-pill {
    padding: 0.55rem 0.85rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: rgba(58, 143, 212, 0.08);
    font-size: 0.78rem;
  }

  .metric-pill strong {
    display: block;
    color: var(--brand-blue-light);
    font-size: 0.95rem;
  }

  .metric-pill span {
    color: var(--text-muted);
  }
</style>
