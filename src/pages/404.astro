---
import Layout from '../layouts/Layout.astro';
import CtaBand from '../components/CtaBand.astro';
---

<Layout
  title="Page Not Found"
  description="The page you are looking for could not be found on Brandtrove."
  path="/404"
  noindex={true}
>
  <section class="section" style="text-align:center;padding-top:6rem">
    <div class="container">
      <span class="eyebrow">404</span>
      <h1>Page Not Found</h1>
      <p class="lead" style="margin-inline:auto">
        The page you requested does not exist. Explore our services or start a strategic partnership inquiry.
      </p>
      <div class="hero-actions" style="justify-content:center">
        <a class="btn btn-primary" href="/">Go Home</a>
        <a class="btn btn-secondary" href="/contact">Contact Us</a>
      </div>
    </div>
  </section>
  <CtaBand title="Let's build your next brand collaboration" href="/contact" />
</Layout>
