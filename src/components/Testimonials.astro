---
import { TESTIMONIALS } from '../data/testimonials';
---

<section class="section section-tight testimonials-section" aria-labelledby="testimonials-heading">
  <div class="container">
    <div class="section-head centered">
      <span class="eyebrow">Client Perspectives</span>
      <h2 id="testimonials-heading">What Partners Say</h2>
      <p class="lead fine-disclaimer">
        Representative feedback reflecting typical engagement outcomes across sports, creator, and brand partnership programs.
      </p>
    </div>
    <div class="testimonials-grid">
      {
        TESTIMONIALS.map((t) => (
          <blockquote class="testimonial-card">
            <p class="testimonial-quote">"{t.quote}"</p>
            <footer class="testimonial-author">
              <span class="testimonial-avatar" aria-hidden="true">{t.initials}</span>
              <div>
                <strong>{t.name}</strong>
                <span>{t.role} · {t.company}</span>
              </div>
            </footer>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>

<style>
  .fine-disclaimer {
    font-size: 0.88rem;
    color: var(--text-muted);
    max-width: 52ch;
    margin-inline: auto;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .testimonial-card {
    margin: 0;
    padding: 1.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-card);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-height: 100%;
  }

  .testimonial-quote {
    margin: 0;
    color: var(--text-muted);
    font-style: italic;
    line-height: 1.75;
    font-size: 0.95rem;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-top: auto;
  }

  .testimonial-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 0.75rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--brand-blue), var(--productive-green-deep));
    color: #fff;
    flex-shrink: 0;
  }

  .testimonial-author strong {
    display: block;
    font-size: 0.92rem;
    color: var(--text);
  }

  .testimonial-author span {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>
