---
import { SITE } from '../data/site';
import { IMAGES } from '../data/images';
---

<section class="hero hero-visual">
  <div class="hero-bg" aria-hidden="true">
    <img src={IMAGES.hero} alt="" loading="eager" fetchpriority="high" decoding="async" width="1920" height="1080" />
    <div class="hero-overlay"></div>
  </div>
  <div class="container hero-inner">
    <div class="hero-copy">
      <span class="eyebrow">Strategic Brand Partnerships</span>
      <h1>{SITE.tagline}</h1>
      <p class="lead">{SITE.description}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/contact">Start a Project</a>
        <a class="btn btn-secondary" href="/services">Explore Services</a>
      </div>
    </div>
    <div class="hero-stats">
      <div class="stat-card">
        <strong>Sports</strong>
        <span>Athletes & leagues</span>
      </div>
      <div class="stat-card">
        <strong>Entertainment</strong>
        <span>Celebrities & media</span>
      </div>
      <div class="stat-card">
        <strong>Digital</strong>
        <span>Creators & influencers</span>
      </div>
      <div class="stat-card accent">
        <strong>India → Global</strong>
        <span>Structured execution</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-visual {
    padding: 5rem 0 4rem;
    min-height: min(92vh, 900px);
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(105deg, rgba(0, 0, 0, 0.92) 0%, rgba(0, 0, 0, 0.78) 42%, rgba(0, 0, 0, 0.55) 100%),
      linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.85));
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    align-items: end;
  }

  .hero-copy h1 {
    max-width: 14ch;
    text-transform: none;
    font-family: var(--font-display);
    letter-spacing: -0.02em;
  }

  .hero-stats {
    display: grid;
    gap: 0.85rem;
  }

  .stat-card {
    padding: 1rem 1.15rem;
    border-radius: 14px;
    background: rgba(10, 15, 24, 0.72);
    border: 1px solid var(--border);
    backdrop-filter: blur(10px);
  }

  .stat-card strong {
    display: block;
    font-family: var(--font-display);
    color: var(--brand-blue-light);
    font-size: 1.05rem;
  }

  .stat-card span {
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  .stat-card.accent {
    border-color: rgba(156, 212, 58, 0.35);
    background: linear-gradient(135deg, rgba(46, 127, 212, 0.12), rgba(156, 212, 58, 0.08));
  }

  .stat-card.accent strong {
    color: var(--productive-green);
  }

  @media (max-width: 960px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-stats {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 560px) {
    .hero-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
