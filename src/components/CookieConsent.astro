<div id="cookie-consent" class="cookie-banner" hidden role="dialog" aria-labelledby="cookie-title" aria-live="polite">
  <div class="cookie-inner">
    <p id="cookie-title">
      We use essential cookies and optional analytics to improve our site.
      <a href="/cookie-policy">Cookie policy</a>
    </p>
    <div class="cookie-actions">
      <button type="button" class="btn btn-secondary btn-sm" data-cookie="decline">Decline analytics</button>
      <button type="button" class="btn btn-primary btn-sm" data-cookie="accept">Accept</button>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 90;
    max-width: 520px;
    margin-inline: auto;
  }

  .cookie-inner {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1rem 1.1rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.45);
  }

  .cookie-inner p {
    margin: 0 0 0.85rem;
    font-size: 0.92rem;
    color: var(--text-muted);
  }

  .cookie-inner a {
    color: var(--brand-blue-light);
  }

  .cookie-actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .btn-sm {
    padding: 0.55rem 0.9rem;
    font-size: 0.85rem;
  }
</style>

<script>
  const KEY = 'brandtrove_cookie_consent';
  const banner = document.getElementById('cookie-consent');
  const hasAnalytics = document.querySelector('script[src*="googletagmanager"]');

  if (banner && hasAnalytics && !localStorage.getItem(KEY)) {
    banner.hidden = false;
  }

  banner?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-cookie]');
    if (!btn) return;
    localStorage.setItem(KEY, btn.getAttribute('data-cookie') === 'accept' ? 'accepted' : 'declined');
    banner.hidden = true;
    if (btn.getAttribute('data-cookie') === 'declined' && typeof (window as any).gtag === 'function') {
      (window as any)['ga-disable-' + (window as any).gaId] = true;
    }
  });
</script>
