---
import { SITE } from '../data/site';
const { url, name } = SITE.poweredBy;
---

<p class="powered-by">
  <a href={url} target="_blank" rel="noopener noreferrer" aria-label={`${SITE.poweredBy.shortLabel} ${name}`}>
    <span class="muted">{SITE.poweredBy.shortLabel}</span>
    <span class="highlight">{SITE.poweredBy.highlight}</span>
    <span class="suffix">{SITE.poweredBy.suffix}</span>
  </a>
</p>

<style>
  .powered-by {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .powered-by a {
    color: inherit;
    text-decoration: none;
  }

  .powered-by a:hover {
    opacity: 0.9;
  }

  .muted {
    color: var(--brand-blue-light);
    margin-right: 0.35rem;
  }

  .highlight {
    color: var(--productive-green);
    margin-right: 0.1rem;
  }

  .suffix {
    color: var(--brand-blue-light);
  }
</style>
