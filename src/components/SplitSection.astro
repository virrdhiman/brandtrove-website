---
interface Props {
  image: string;
  alt: string;
  eyebrow?: string;
  title: string;
  description?: string;
  href?: string;
  linkLabel?: string;
  reverse?: boolean;
}

const { image, alt, eyebrow, title, description, href, linkLabel = 'Learn more', reverse = false } = Astro.props;
---

<section class:list={['split-section', 'section', { reverse }]}>
  <div class="container split-grid">
    <div class="split-media">
      <img src={image} alt={alt} loading="lazy" width="640" height="480" />
      <div class="split-glow" aria-hidden="true"></div>
    </div>
    <div class="split-content">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2>{title}</h2>
      {description && <p class="lead">{description}</p>}
      <slot />
      {href && <a class="text-link" href={href}>{linkLabel} →</a>}
    </div>
  </div>
</section>

<style>
  .split-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .reverse .split-grid {
    direction: rtl;
  }

  .reverse .split-grid > * {
    direction: ltr;
  }

  .split-media {
    position: relative;
    border-radius: calc(var(--radius) + 6px);
    overflow: hidden;
    border: 1px solid var(--border);
    min-height: 320px;
  }

  .split-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    min-height: 320px;
    transition: transform 0.5s ease;
  }

  .split-media:hover img {
    transform: scale(1.03);
  }

  .split-glow {
    position: absolute;
    inset: auto 0 0;
    height: 45%;
    background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.65));
  }

  .text-link {
    display: inline-block;
    margin-top: 1.25rem;
    color: var(--brand-blue-light);
    font-weight: 600;
  }

  .text-link:hover {
    color: var(--productive-green);
  }

  .split-content ul {
    color: var(--text-muted);
    padding-left: 1.2rem;
    margin: 1rem 0 0;
  }

  .split-content li + li {
    margin-top: 0.45rem;
  }

  @media (max-width: 900px) {
    .split-grid {
      grid-template-columns: 1fr;
    }

    .reverse .split-grid {
      direction: ltr;
    }
  }
</style>
