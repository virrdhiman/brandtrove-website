---
import { SITE } from '../data/site';

const web3Key = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? '';
---

<section class="section-tight" id="inquiry">
  <div class="container">
    <div class="card form-card">
      <span class="eyebrow">Strategic Partnership Inquiry</span>
      <h2>Start a Project</h2>
      <p>Tell us about your brand, collaboration goals, and timeline. Our team will respond with next steps.</p>

      <div id="form-success" class="form-status success" hidden role="status" tabindex="-1">
        <strong>Thank you — your inquiry was sent.</strong>
        <p>We'll review your details and respond at the email you provided within 1–2 business days.</p>
      </div>

      <div id="form-error" class="form-status error" hidden role="alert">
        <strong>Could not send your inquiry.</strong>
        <p>Please email us directly at <a href={`mailto:${SITE.email}`}>{SITE.email}</a> or call {SITE.phoneDisplay}.</p>
      </div>

      <form id="contact-form" class="form-grid" method="post" action="#" novalidate>
        <div class="form-grid two">
          <label>
            First Name
            <input name="firstName" required autocomplete="given-name" />
          </label>
          <label>
            Last Name
            <input name="lastName" required autocomplete="family-name" />
          </label>
        </div>
        <div class="form-grid two">
          <label>
            Company Name
            <input name="company" required autocomplete="organization" />
          </label>
          <label>
            Business Email
            <input type="email" name="email" required autocomplete="email" />
          </label>
        </div>
        <div class="form-grid two">
          <label>
            Industry
            <select name="industry" required>
              <option value="">Select industry</option>
              <option>FMCG</option>
              <option>Technology</option>
              <option>Financial Services</option>
              <option>Lifestyle & Fashion</option>
              <option>Entertainment & Media</option>
              <option>Startup / Growth Stage</option>
              <option>Other</option>
            </select>
          </label>
          <label>
            Type of Collaboration
            <select name="collaboration" required>
              <option value="">Select type</option>
              <option>Sports Partnership</option>
              <option>Celebrity / Athlete Endorsement</option>
              <option>Influencer Campaign</option>
              <option>Event or Activation</option>
              <option>Global Collaboration</option>
              <option>Other</option>
            </select>
          </label>
        </div>
        <div class="form-grid two">
          <label>
            Budget Range
            <select name="budget">
              <option value="">Select range</option>
              <option>Under ₹10L</option>
              <option>₹10L – ₹50L</option>
              <option>₹50L – ₹1Cr</option>
              <option>₹1Cr+</option>
            </select>
          </label>
          <label>
            Timeline
            <select name="timeline">
              <option value="">Select timeline</option>
              <option>Immediate (0–30 days)</option>
              <option>1–3 months</option>
              <option>3–6 months</option>
              <option>6+ months</option>
            </select>
          </label>
        </div>
        <label>
          Partnership Details
          <textarea name="details" placeholder="Share campaign goals, audience, and any talent preferences."></textarea>
        </label>
        <label class="checkbox-row">
          <input type="checkbox" name="goalsDefined" required />
          <span>I have defined project goals and budget parameters for this inquiry.</span>
        </label>
        <input type="hidden" name="_subject" value="New Brandtrove partnership inquiry" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
        <button class="btn btn-primary" type="submit" id="form-submit">Send Inquiry</button>
      </form>
      <p class="fine-print">By submitting, you agree to our <a href="/privacy-policy">Privacy Policy</a>. For direct contact: <a href={`mailto:${SITE.email}`}>{SITE.email}</a></p>
    </div>
  </div>
</section>

<style>
  .form-card {
    max-width: 820px;
    margin-inline: auto;
  }

  .form-status {
    padding: 1rem 1.1rem;
    border-radius: var(--radius-md);
    margin-bottom: 1.25rem;
  }

  .form-status.success {
    background: rgba(34, 197, 94, 0.12);
    border: 1px solid rgba(34, 197, 94, 0.35);
  }

  .form-status.error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.35);
  }

  .form-status p {
    margin: 0.35rem 0 0;
    font-size: 0.92rem;
  }

  .fine-print {
    margin-top: 1rem;
    font-size: 0.88rem;
  }

  .fine-print a {
    color: var(--gold-soft);
  }

  .btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }
</style>

<script define:vars={{ email: SITE.email, web3Key }}>
  const form = document.getElementById('contact-form');
  const success = document.getElementById('form-success');
  const error = document.getElementById('form-error');
  const submitBtn = document.getElementById('form-submit');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!(form instanceof HTMLFormElement)) return;
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const honey = form.querySelector('[name="_honey"]');
    if (honey instanceof HTMLInputElement && honey.value) return;

    submitBtn?.setAttribute('disabled', 'true');
    error?.setAttribute('hidden', '');
    success?.setAttribute('hidden', '');

    const data = Object.fromEntries(new FormData(form).entries());

    try {
      let ok = false;

      if (web3Key) {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            access_key: web3Key,
            subject: 'New Brandtrove partnership inquiry',
            from_name: `${data.firstName} ${data.lastName}`,
            email: data.email,
            message: [
              `Company: ${data.company}`,
              `Industry: ${data.industry}`,
              `Collaboration: ${data.collaboration}`,
              `Budget: ${data.budget || 'Not specified'}`,
              `Timeline: ${data.timeline || 'Not specified'}`,
              '',
              String(data.details || ''),
            ].join('\n'),
          }),
        });
        const json = await res.json();
        ok = json.success === true;
      } else {
        const res = await fetch(`https://formsubmit.co/ajax/${email}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            ...data,
            _subject: 'New Brandtrove partnership inquiry',
            _template: 'table',
          }),
        });
        ok = res.ok;
      }

      if (ok) {
        form.reset();
        success?.removeAttribute('hidden');
        success?.focus();
      } else {
        throw new Error('submit failed');
      }
    } catch {
      error?.removeAttribute('hidden');
    } finally {
      submitBtn?.removeAttribute('disabled');
    }
  });
</script>
