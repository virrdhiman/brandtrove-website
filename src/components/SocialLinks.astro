---
import { SOCIAL_PROFILES } from '../data/site';

const profiles = SOCIAL_PROFILES.filter((profile) => profile.url);
---

{
  profiles.length > 0 && (
    <nav class="social-links" aria-label="Follow Brandtrove on social media">
      <p class="social-label">Follow us</p>
      <ul class="social-grid">
        {profiles.map((profile) => (
          <li>
            <a
              href={profile.url}
              class={`social-card social-${profile.key}`}
              rel="noopener noreferrer"
              target="_blank"
              aria-label={`${profile.label} (opens in new tab)`}
            >
              <span class="social-icon" aria-hidden="true">
                {profile.key === 'linkedin' && (
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zm1.78 13.02H3.56V9h3.56v11.45z" />
                  </svg>
                )}
                {profile.key === 'instagram' && (
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.43-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07zm0-2.16C8.74 0 8.33.01 7.05.07 5.78.13 4.9.34 4.15.63c-.78.3-1.44.7-2.1 1.36-.66.66-1.06 1.32-1.36 2.1-.29.75-.5 1.63-.56 2.9C.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.27 2.15.56 2.9.3.78.7 1.44 1.36 2.1.66.66 1.32 1.06 2.1 1.36.75.29 1.63.5 2.9.56 1.28.06 1.69.07 4.95.07s3.67-.01 4.95-.07c1.27-.06 2.15-.27 2.9-.56.78-.3 1.44-.7 2.1-1.36.66-.66 1.06-1.32 1.36-2.1.29-.75.5-1.63.56-2.9.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.27-2.15-.56-2.9-.3-.78-.7-1.44-1.36-2.1-.66-.66-1.32-1.06-2.1-1.36-.75-.29-1.63-.5-2.9-.56C15.67.01 15.26 0 12 0z" />
                    <path d="M12 5.84A6.16 6.16 0 1 0 18.16 12 6.16 6.16 0 0 0 12 5.84zm0 10.16A4 4 0 1 1 16 12a4 4 0 0 1-4 4zm7.85-10.4a1.44 1.44 0 1 1-1.44-1.44 1.44 1.44 0 0 1 1.44 1.44z" />
                  </svg>
                )}
                {profile.key === 'x' && (
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M18.9 2H22l-6.77 7.74L23.2 22h-6.7l-5.24-6.85L5.5 22H2.4l7.24-8.28L.8 2h6.86l4.73 6.2L18.9 2zm-1.17 18h1.86L7.17 3.9H5.2L17.73 20z" />
                  </svg>
                )}
                {profile.key === 'facebook' && (
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M24 12.07C24 5.41 18.63 0 12 0S0 5.41 0 12.07C0 18.09 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.8-4.69 4.56-4.69 1.32 0 2.7.24 2.7.24v2.97h-1.52c-1.5 0-1.97.93-1.97 1.88v2.26h3.35l-.54 3.49h-2.81V24C19.61 23.1 24 18.09 24 12.07z" />
                  </svg>
                )}
              </span>
              <span class="social-name">{profile.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  .social-links {
    margin: 1.35rem 0 1rem;
    padding: 1.15rem 1.2rem 1.25rem;
    border-radius: var(--radius);
    border: 1px solid rgba(110, 192, 245, 0.28);
    background:
      radial-gradient(120% 80% at 0% 0%, rgba(58, 143, 212, 0.14), transparent 55%),
      linear-gradient(160deg, rgba(11, 18, 32, 0.98), rgba(0, 0, 0, 0.92));
    box-shadow:
      0 16px 40px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(110, 192, 245, 0.12);
  }

  .social-label {
    margin: 0 0 0.9rem;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brand-blue-light);
  }

  .social-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .social-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 5.25rem;
    padding: 0.85rem 0.65rem;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(0, 0, 0, 0.45);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease;
  }

  .social-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.22;
    background: var(--social-gradient);
    transition: opacity 0.22s ease;
  }

  .social-card::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 3px;
    background: var(--social-accent);
    transform: scaleX(0.35);
    transform-origin: center;
    transition: transform 0.22s ease;
  }

  .social-icon,
  .social-name {
    position: relative;
    z-index: 1;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.65rem;
    height: 2.65rem;
    border-radius: 50%;
    background: var(--social-gradient);
    box-shadow:
      0 8px 20px color-mix(in srgb, var(--social-accent) 45%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.22);
  }

  .social-icon svg {
    width: 1.35rem;
    height: 1.35rem;
    fill: #fff;
  }

  .social-name {
    line-height: 1.1;
    color: rgba(255, 255, 255, 0.92);
  }

  .social-linkedin {
    --social-accent: #0a66c2;
    --social-gradient: linear-gradient(135deg, #0a66c2, #004182);
  }

  .social-instagram {
    --social-accent: #e4405f;
    --social-gradient: linear-gradient(135deg, #f58529, #dd2a7b, #8134af);
  }

  .social-x {
    --social-accent: #e7e9ea;
    --social-gradient: linear-gradient(135deg, #2a2a2a, #000);
  }

  .social-facebook {
    --social-accent: #1877f2;
    --social-gradient: linear-gradient(135deg, #1877f2, #0d5dbf);
  }

  .social-card:hover,
  .social-card:focus-visible {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--social-accent) 65%, white);
    box-shadow: 0 14px 28px color-mix(in srgb, var(--social-accent) 32%, transparent);
    outline: none;
  }

  .social-card:hover::before,
  .social-card:focus-visible::before {
    opacity: 0.38;
  }

  .social-card:hover::after,
  .social-card:focus-visible::after {
    transform: scaleX(1);
  }

  .social-card:focus-visible {
    box-shadow:
      0 0 0 2px var(--bg),
      0 0 0 4px var(--brand-blue-light),
      0 14px 28px color-mix(in srgb, var(--social-accent) 32%, transparent);
  }

  @media (min-width: 480px) {
    .social-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 479px) {
    .social-card {
      min-height: 4.75rem;
    }
  }
</style>
